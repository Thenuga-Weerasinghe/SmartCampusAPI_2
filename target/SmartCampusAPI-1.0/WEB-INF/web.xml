<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Smart Campus API</display-name>

    <!--
        ════════════════════════════════════════════════════════════
        SERVLET DECLARATION
        We register Jersey's ServletContainer as a servlet.
        A "servlet" is a Java class that handles HTTP requests.
        Jersey's ServletContainer receives all requests and
        routes them to the correct @Path resource class.

        Think of this like registering a receptionist:
        "When someone comes to this building (Tomcat),
         the receptionist (Jersey) will direct them."
        ════════════════════════════════════════════════════════════
    -->
    <servlet>
        <servlet-name>SmartCampusJersey</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>

        <!--
            This init-param tells Jersey: "scan all classes in the
            com.smartcampus package and its sub-packages. Register
            anything annotated with @Path, @Provider, etc."
            This is how Jersey finds your resource classes
            and exception mappers automatically.
        -->
        <init-param>
            <param-name>jersey.config.server.provider.packages</param-name>
            <param-value>com.smartcampus</param-value>
        </init-param>

        <!--
            This tells Jersey to use Jackson for JSON conversion.
            Without this, Jersey won't know how to convert
            Java objects to JSON or parse incoming JSON.
        -->
        <init-param>
            <param-name>jersey.config.server.provider.classnames</param-name>
            <param-value>org.glassfish.jersey.jackson.JacksonFeature</param-value>
        </init-param>

        <!--
            load-on-startup=1 means: start Jersey immediately when
            Tomcat starts, don't wait for the first request.
            This is faster for the first API call.
        -->
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!--
        ════════════════════════════════════════════════════════════
        SERVLET MAPPING
        This tells Tomcat: "Any request to /api/v1/* should be
        sent to the SmartCampusJersey servlet."

        URL pattern breakdown:
        http://localhost:8080  ← Tomcat's address and port
        /SmartCampusAPI        ← Context root (your app name)
        /api/v1/rooms          ← Matched by /api/v1/* → sent to Jersey
                                  Jersey then routes to @Path("/rooms")
        ════════════════════════════════════════════════════════════
    -->
    <servlet-mapping>
        <servlet-name>SmartCampusJersey</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>